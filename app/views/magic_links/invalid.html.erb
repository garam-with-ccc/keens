<% content_for :title, "Sign-in link invalid" %>

<section class="w-full max-w-md mx-auto text-center">
  <h1 class="text-3xl font-semibold tracking-tight mb-4">Link expired or already used</h1>
  <p class="text-neutral-300 mb-8">
    Sign-in links are good for one use and expire after 20 minutes.
    Request a new one to continue.
  </p>
  <%= link_to "Request a new link", sign_in_path,
        class: "rounded bg-neutral-50 px-4 py-2 text-neutral-950 font-medium hover:bg-neutral-200" %>
</section>
