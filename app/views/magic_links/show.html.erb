<% content_for :title, "Confirm sign in" %>

<section class="w-full max-w-md mx-auto text-center">
  <h1 class="text-3xl font-semibold tracking-tight mb-4">Confirm sign in</h1>
  <p class="text-neutral-300 mb-8">Click below to finish signing in to Keens.</p>

  <%= button_to "Sign in to Keens",
        consume_magic_link_path(token: @token),
        method: :post,
        class: "rounded bg-neutral-50 px-4 py-2 text-neutral-950 font-medium hover:bg-neutral-200 cursor-pointer" %>
</section>
